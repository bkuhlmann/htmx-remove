#! /usr/bin/env bash

set -o nounset
set -o errexit
set -o pipefail
IFS=$'\n\t'

if ! command -v entr > /dev/null; then
  printf "%s" "ERROR: Entr isn't installed: https://eradman.com/entrproject. "
  printf "%s\n" "To fix, run: brew install entr."

  exit 1
fi

build_and_serve() {
  rm -rf tmp/demo
  mkdir -p tmp/demo
  cp -r demo/ tmp/demo
  cp lib/*.js tmp/demo

  ruby -run -e httpd tmp/demo --port 3030
}

export -f build_and_serve

find lib demo -type f | entr -s -r "build_and_serve"
